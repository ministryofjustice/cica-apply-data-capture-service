{
    "name": "data-capture-service",
    "version": "9.8.9",
    "engines": {
        "npm": ">=10.8.2",
        "node": ">=24.13.0"
    },
    "scripts": {
        "start": "node ./bin/www",
        "start:dev": "nodemon -L -e .js,.json,.njk,.yml --exec npm run build:run:dev",
        "lint:openapi": "redocly lint openapi/openapi.json",
        "lint:openapi-admin": "redocly lint openapi/openapi-admin.json",
        "build:run:dev": "node --inspect=0.0.0.0:9229 ./bin/www",
        "pretestx": "eslint .",
        "test": "jest",
        "coverage": "jest --coverage",
        "dump-eslint-conf": "eslint --print-config ./app.js > ./stuff/eslint-conf.json",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "check-supported-versions": "node ./scripts/init"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.345.0",
        "@aws-sdk/client-sqs": "^3.345.0",
        "ajv": "^8.18.0",
        "ajv-errors": "^3.0.0",
        "ajv-formats-mobile-uk": "github:CriminalInjuriesCompensationAuthority/ajv-formats-mobile-uk#v1.0.0",
        "cookie-parser": "~1.4.3",
        "debug": "~4.4.3",
        "express": "^5.2.1",
        "express-jwt": "^8.0.0",
        "express-jwt-authz": "^2.4.1",
        "express-openapi-validator": "^5.5.3",
        "helmet": "^8.1.0",
        "json-translator": "github:CriminalInjuriesCompensationAuthority/json-translator#v2.0.0",
        "jsonpointer": "^5.0.0",
        "pg": "^8.7.3",
        "pino-http": "^11.0.0",
        "pino-std-serializers": "^7.1.0",
        "q-expressions": "github:CriminalInjuriesCompensationAuthority/q-expressions#v1.1.0",
        "q-router": "github:CriminalInjuriesCompensationAuthority/q-router#semver:3.2.2",
        "q-templates-application": "github:CriminalInjuriesCompensationAuthority/q-templates-application#semver:v12.4.10",
        "q-templates-application-12_4_0": "github:CriminalInjuriesCompensationAuthority/q-templates-application#v12.4.0",
        "q-templates-application-12_4_1": "github:CriminalInjuriesCompensationAuthority/q-templates-application#v12.4.1",
        "q-templates-application-12_4_2": "github:CriminalInjuriesCompensationAuthority/q-templates-application#v12.4.2",
        "q-templates-application-12_4_3": "github:CriminalInjuriesCompensationAuthority/q-templates-application#semver:12.4.3",
        "q-templates-application-12_4_4": "github:CriminalInjuriesCompensationAuthority/q-templates-application#v12.4.4",
        "q-templates-application-12_4_6": "github:CriminalInjuriesCompensationAuthority/q-templates-application#v12.4.6",
        "q-templates-application-12_4_7": "github:CriminalInjuriesCompensationAuthority/q-templates-application#v12.4.7",
        "q-templates-application-12_4_8": "github:CriminalInjuriesCompensationAuthority/q-templates-application#v12.4.8",
        "semver": "^7.5.4",
        "swagger-ui-express": "^5.0.1",
        "verror": "^1.10.0"
    },
    "devDependencies": {
        "@redocly/cli": "^2.16.0",
        "aws-sdk-client-mock": "^4.1.0",
        "eslint": "^10.2.1",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.19.1",
        "eslint-plugin-jest": "^29.15.2",
        "eslint-plugin-prettier": "^5.5.5",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "lint-staged": "^16.4.0",
        "nodemon": "^3.0.0",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.8.3",
        "supertest": "^7.2.2",
        "yamljs": "^0.3.0"
    },
    "overrides": {
        "fast-xml-parser": "5.5.7",
        "js-yaml": "4.1.1"
    },
    "license": "MIT"
}
