{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "additionalProperties": false,
    "required": ["data"],
    "properties": {
        "data": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "attributes"],
            "properties": {
                "type": {
                    "const": "questionnaires"
                },
                "attributes": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["questionnaireIds"],
                    "properties": {
                        "questionnaireIds": {
                            "type": "array",
                            "minItems": 1,
                            "items": {
                                "type": "string",
                                "format": "uuid"
                            }
                        }
                    }
                }
            }
        }
    }
}
